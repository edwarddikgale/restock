{
  "name": "restock",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --names \"app,api\" --prefix-colors \"cyan,yellow\" \"npm run dev:app\" \"npm run dev:api\"",
    "dev:app": "npm --prefix app/restock run dev",
    "dev:api": "npm --prefix api/restock-api run serve",
    "build:app": "npm --prefix app/restock run build",
    "build:api": "npm --prefix api/restock-api run build"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
